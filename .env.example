# === Azure Voice Live (Realtime API) ===
AZURE_VOICELIVE_ENDPOINT=wss://YOUR-RESOURCE.openai.azure.com
AZURE_VOICELIVE_API_KEY=your-voicelive-api-key
# Supported models: gpt-realtime, gpt-realtime-mini, gpt-4o, gpt-4o-mini,
# gpt-4.1, gpt-4.1-mini, gpt-5, gpt-5-mini, gpt-5-nano, gpt-5-chat,
# phi4-mm-realtime, phi4-mini
# See: https://learn.microsoft.com/en-us/azure/ai-services/speech-service/voice-live#supported-models-and-regions
AZURE_VOICELIVE_MODEL=gpt-4o

# === Azure OpenAI (for LangGraph agents) ===
AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE.openai.azure.com/
AZURE_OPENAI_API_KEY=your-openai-api-key
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# === Voice Configuration ===
# Azure TTS voice name (https://learn.microsoft.com/azure/ai-services/speech-service/language-support?tabs=tts)
VOICE_NAME=en-US-AvaMultilingualNeural
STT_LANGUAGE=en-US
STT_MODEL=azure-speech

# === Audio Settings ===
AUDIO_SAMPLE_RATE=24000
AUDIO_CHANNELS=1
AUDIO_CHUNK_MS=50
